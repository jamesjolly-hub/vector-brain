{
  "name": "vector-brain",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler d1 migrations apply vector-brain --remote && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:create": "wrangler d1 create vector-brain",
    "db:migrate:local": "wrangler d1 migrations apply vector-brain --local",
    "db:migrate:remote": "wrangler d1 migrations apply vector-brain --remote",
    "vector:create": "npx wrangler vectorize create corpus-index --dimensions 768 --metric cosine"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.10.0",
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
